# PrêtImmoPro — modèle d’environnement pour Docker uniquement
#
# Ce projet est prévu pour tourner via docker compose (pas de next dev / next start sur l’hôte).
# Copie : cp .env.example .env puis édite `.env` (le fichier `.env` reste ignoré par git).
#
# Prérequis infra : réseau Docker externe `postgres_network` (voir `.cursor/rules/infrastructure-vps.mdc`).

# ── Publication (hôte → conteneur, voir docker-compose.yml) ─────────────────
HOST_PORT=3000

# ── Build-time (build.args → Dockerfile) ────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://pretimmopro.fr
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_NO_INDEX=false
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_MATOMO_URL=https://analytics.votredomaine.fr
NEXT_PUBLIC_MATOMO_SITE_ID=1

# ── Runtime dans le conteneur (environment du service web) ─────────────────
ADSENSE_CERT_AUTH_ID=f08c47fec0942fa0
ADS_TXT_EXTRA=

# ── Optionnel ───────────────────────────────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Futur : Postgres partagé (hôte `postgres`, port 5432, user admin)
# DATABASE_URL=postgresql://admin:MOT_DE_PASSE@postgres:5432/pretimmopro

# Futur : Keycloak partagé
# KEYCLOAK_ISSUER=https://auth.example/realms/votre-realm
