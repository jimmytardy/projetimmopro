# Copier ce fichier en .env.local et remplir les vraies valeurs

# ── Serveur ────────────────────────────────────────────────────────────────────
# Port d'écoute pour `npm run dev` et `npm run start`.
# dotenv-cli charge ce fichier AVANT Next.js, rendant PORT disponible au démarrage.
PORT=3100

# ── Site ──────────────────────────────────────────────────────────────────────
# URL de production (sans slash final)
NEXT_PUBLIC_SITE_URL=https://pretimmopro.fr

# ── Google Search Console ─────────────────────────────────────────────────────
# Balise meta verification (valeur du content="..." fournie par Google)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Désindexer tout le site (préprod, duplicate, etc.) — robots disallow + meta noindex
NEXT_PUBLIC_NO_INDEX=false

# ── AdSense ───────────────────────────────────────────────────────────────────
# Récupérer sur https://www.google.com/adsense/
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# ads.txt — ID de certification d'autorité (visible dans Paramètres AdSense → Accès et autorisations → ads.txt)
# Format de la ligne générée : google.com, pub-XXXX, DIRECT, <ADSENSE_CERT_AUTH_ID>
ADSENSE_CERT_AUTH_ID=f08c47fec0942fa0

# Autres entrées ads.txt pour d'autres régies (optionnel, séparées par \n)
# Ex : openx.com, 123456, DIRECT\nappnexus.com, 789, RESELLER
ADS_TXT_EXTRA=

# ── Matomo Analytics ──────────────────────────────────────────────────────────
# URL de votre instance Matomo (auto-hébergée ou Matomo Cloud), sans slash final
# Ex : https://analytics.pretimmopro.fr  ou  https://pretimmopro.matomo.cloud
NEXT_PUBLIC_MATOMO_URL=https://analytics.votredomaine.fr

# ID du site dans Matomo (Paramètres → Sites web → Voir tout → colonne ID)
NEXT_PUBLIC_MATOMO_SITE_ID=1

# ── Google Analytics 4 (optionnel, remplacé par Matomo) ──────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Docker / VPS (voir .env.docker.example + docker-compose.yml) ────────────
# Docker Compose charge un fichier `.env` à la racine pour la substitution des variables.
# Copier .env.docker.example vers `.env` sur le serveur (ou fusionner avec vos secrets).
# Réseau externe obligatoire : postgres_network (créé par la stack Postgres partagée).
# HOST_PORT=3000
