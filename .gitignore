# ─── Next.js ──────────────────────────────────────────────────────────────────
.next/
out/
build/

# ─── Dépendances ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ─── Variables d'environnement ────────────────────────────────────────────────
# Ne jamais versionner les clés (AdSense, GA, etc.)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Fichier d'exemple OK à versionner (sans vraies valeurs)
!.env.example

# ─── Sitemap & robots (générés au build) ─────────────────────────────────────
public/sitemap*.xml
public/robots.txt

# ─── Logs ─────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Tests & couverture ───────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── IDE & éditeurs ───────────────────────────────────────────────────────────
.idea/
*.swp
*.swo
*~
.vscode/settings.json
.vscode/launch.json
# Garder les extensions recommandées et les snippets partagés
!.vscode/extensions.json
!.vscode/snippets/

# ─── Cursor ───────────────────────────────────────────────────────────────────
# Caches locaux ignorés, rules versionnées et partagées
.cursor/cache/
.cursor/tmp/
!.cursor/rules/

# ─── Système d'exploitation ───────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Vercel ───────────────────────────────────────────────────────────────────
.vercel/

