# Variables lues par docker-compose.yml (substitution depuis un fichier `.env` à la racine,
# ou exportées dans le shell avant `docker compose up --build`).
#
# Sur le VPS : placer le projet sous ~/shared-project/ et s’assurer que le réseau
# `postgres_network` existe (stack Postgres partagée).

HOST_PORT=3000

# Build-time (doivent correspondre aux ARG du Dockerfile si vous changez les défauts)
NEXT_PUBLIC_SITE_URL=https://pretimmopro.fr
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_NO_INDEX=false
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_MATOMO_URL=
NEXT_PUBLIC_MATOMO_SITE_ID=

# Runtime (serveur Next)
ADSENSE_CERT_AUTH_ID=
ADS_TXT_EXTRA=

# Futur : base sur Postgres partagé (hôte `postgres`, port 5432, user admin)
# DATABASE_URL=postgresql://admin:MOT_DE_PASSE@postgres:5432/pretimmopro

# Futur : Keycloak partagé (ne pas lancer Keycloak dans ce repo)
# KEYCLOAK_ISSUER=https://votre-domaine:8080/realms/votre-realm
